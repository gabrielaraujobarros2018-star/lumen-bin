#!/bin/bash
# lsmod - list loaded kernel modules
# Minimal reimplementation reading from /proc/modules

usage() {
    cat <<EOF
Usage: lsmod
       lsmod -h

Show list of currently loaded kernel modules (parses /proc/modules)
EOF
    exit 0
}

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
fi

if [ ! -r /proc/modules ]; then
    echo "lsmod: /proc/modules not readable or not available" >&2
    echo "Kernel may not have module support or procfs not mounted" >&2
    exit 1
fi

printf "%-24s %-8s %-12s %s\n" "Module" "Size" "Used by" "Depends/Info"

while read -r line; do
    # Format of /proc/modules:
    # module_name size refcnt used_by_list state address
    mod_name=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    used=$(echo "$line" | awk '{print $3}')

    # used_by can be multiple, comma separated
    used_by=$(echo "$line" | cut -d' ' -f4- | sed 's/ .*//')

    if [ "$used_by" = "-" ]; then
        used_by=""
    fi

    printf "%-24s %8s %4s" "$mod_name" "$size" "$used"
    [ -n "$used_by" ] && printf " %s" "$used_by"
    echo ""
done < /proc/modules | sort